{
  "name": "jmoon-github-cv",
  "version": "1.0.0",
  "description": "Static GitHub Pages-style academic CV website built from the newest `CV_<date>_MOON.docx` in the repo root.",
  "main": "app.js",
  "scripts": {
    "site:data": "py scripts/generate_site_data.py",
    "analytics:scholar": "node scripts/update_research_analytics_scholar.mjs",
    "analytics:update": "node scripts/update_research_analytics_scholar.mjs && py scripts/update_research_analytics.py",
    "site:update": "py scripts/update_site_from_cv.py",
    "site:update:playwright": "py scripts/update_site_from_cv.py --with-playwright",
    "update:biweekly": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cv_biweekly_update.ps1",
    "update:biweekly:register": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register_biweekly_update.ps1",
    "abstracts:base": "py scripts/update_publication_abstracts.py",
    "abstracts:playwright": "node scripts/update_publication_abstracts_playwright.mjs",
    "abstracts:update": "py scripts/update_publication_abstracts.py && node scripts/update_publication_abstracts_playwright.mjs",
    "audit:dark": "node scripts/dark_contrast_audit.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Educatian/cv.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Educatian/cv/issues"
  },
  "homepage": "https://github.com/Educatian/cv#readme",
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "pngjs": "^7.0.0"
  }
}
