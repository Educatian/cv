{
  "name": "jmoon-github-cv",
  "version": "1.0.0",
  "description": "Static GitHub Pages-style academic CV website built from `CV_202604_MOON.docx`.",
  "main": "app.js",
  "scripts": {
    "site:data": "python scripts/generate_site_data.py",
    "analytics:scholar": "node scripts/update_research_analytics_scholar.mjs",
    "analytics:update": "node scripts/update_research_analytics_scholar.mjs && python scripts/update_research_analytics.py",
    "site:update": "python scripts/update_site_from_cv.py",
    "site:update:playwright": "python scripts/update_site_from_cv.py --with-playwright",
    "abstracts:base": "python scripts/update_publication_abstracts.py",
    "abstracts:playwright": "node scripts/update_publication_abstracts_playwright.mjs",
    "abstracts:update": "python scripts/update_publication_abstracts.py && node scripts/update_publication_abstracts_playwright.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Educatian/cv.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Educatian/cv/issues"
  },
  "homepage": "https://github.com/Educatian/cv#readme",
  "dependencies": {
    "playwright": "^1.59.1"
  }
}
